# .env.example for the template

# This file serves as a template for the .env file generated by the deployment script.
# The values here are placeholders and will be overridden during deployment.

# --- Database ---
# The hostname 'db' refers to the database service within the Docker network.
# The database name will be made project-specific by the deployment script.
DATABASE_URL=postgresql://postgres:1122@db:5432/myapp_db

# --- Ports ---
# These are the default ports. The deployment script will prompt for new ones.
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- API Configuration ---
# This URL is used by the SvelteKit frontend to communicate with the FastAPI backend.
# It will be dynamically set by the deployment script based on the chosen backend port.
VITE_API_URL=http://localhost:8000

# Server-side internal API URL (SvelteKit -> FastAPI inside Docker)
API_BASE_URL=http://backend:8000

# CORS Origins (Comma separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Public URL (Used for referencing the public-facing URL)
PUBLIC_URL=http://localhost:5173
